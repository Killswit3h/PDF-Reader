# fastlane — build the iOS app and ship it to TestFlight, unattended.
#
# This lane is the whole "head to toe" iOS release: it signs with certificates
# synced by `match`, stamps a unique build number, archives the Capacitor
# workspace, and uploads to TestFlight for internal testers (no App Review, live
# in minutes). It is called by `npm run ios:beta` and by the `testflight` job in
# .github/workflows/ios.yml.
#
# Everything secret comes from the environment (GitHub Actions secrets in CI, or
# your shell locally) — nothing sensitive is committed. Required env:
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_P8_BASE64   – App Store Connect API key
#   APPLE_TEAM_ID                                   – Apple Developer Team ID
#   MATCH_GIT_URL, MATCH_PASSWORD                   – match certs repo + passphrase
#   MATCH_GIT_BASIC_AUTHORIZATION                   – base64("user:token") to clone it (CI)
#   BUILD_NUMBER (optional)                         – unique build no. (defaults to a timestamp)
#
# The Xcode workspace lives in the git-ignored ios/ project generated by
# `cap add ios`; paths below are relative to the repo root (fastlane's CWD).

default_platform(:ios)

APP_ID    = "com.pdfsigner.app"
WORKSPACE = "ios/App/App.xcworkspace"
PROJECT   = "ios/App/App.xcodeproj"
SCHEME    = "App"
PROFILE   = "match AppStore #{APP_ID}" # the profile name match installs for appstore type

# Marketing version comes from package.json so it tracks the one source of truth
# (the same field the web bundle and Android build read). __dir__ is the fastlane/
# folder, so ../package.json is the repo root regardless of where fastlane is run.
def marketing_version
  require "json"
  JSON.parse(File.read(File.expand_path("../package.json", __dir__)))["version"]
end

platform :ios do
  desc "Build and upload a signed build to TestFlight (internal testers)"
  lane :beta do
    # 1. Authenticate to App Store Connect with an API key (no Apple ID / 2FA).
    #    Used for both cert sync and the TestFlight upload.
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8_BASE64"),
      is_key_content_base64: true,
      in_house: false
    )

    # 2. Sync the App Store distribution cert + provisioning profile from the
    #    private match repo (read-only — creation is a one-time manual `fastlane
    #    match appstore` documented in docs/ios-testflight.md).
    match(
      type: "appstore",
      app_identifier: APP_ID,
      git_url: ENV.fetch("MATCH_GIT_URL"),
      readonly: true,
      api_key: api_key
    )

    # 3. Stamp versions. Marketing version from package.json; build number must be
    #    unique + increasing per upload — CI passes the run number via BUILD_NUMBER;
    #    fall back to a UTC timestamp for local runs.
    increment_version_number(version_number: marketing_version, xcodeproj: PROJECT)
    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || Time.now.utc.strftime("%Y%m%d%H%M"),
      xcodeproj: PROJECT
    )

    # 4. Force manual signing with the match-provisioned profile so the archive is
    #    reproducible and never depends on Xcode's automatic signing.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: PROJECT,
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      bundle_identifier: APP_ID,
      profile_name: PROFILE
    )

    # 5. Archive + export a signed .ipa.
    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/ios-export",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: { APP_ID => PROFILE }
      }
    )

    # 6. Upload to TestFlight. Internal testers get it as soon as Apple finishes
    #    processing — no Beta App Review, no waiting on this job.
    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_ID,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
