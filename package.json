{
  "name": "pdf-signer",
  "version": "1.8.4",
  "description": "Offline app (Windows + macOS + Android) to view large PDFs, organize/merge pages, mark them up, measure by scale, fill forms, number/stamp, and add cosmetic signatures/initials/dates.",
  "main": "src/main.js",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Killswit3h/PDF-Reader.git"
  },
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node test/e2e/run.js",
    "verify": "npm test && npm run test:e2e",
    "fixtures": "node test/fixtures/make-fixtures.js",
    "build:web": "node scripts/build-web.js",
    "verify:web": "npm run build:web && node scripts/verify-web.js",
    "android:icons": "node build/make-android-icons.js android/app/src/main/res",
    "android:add": "npm run build:web && cap add android && npm run android:icons",
    "android:sync": "npm run build:web && cap sync android && npm run android:icons",
    "android:open": "npm run android:sync && cap open android",
    "android:apk": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "dist": "electron-builder --win nsis --x64",
    "dist:arm64": "electron-builder --win nsis --arm64",
    "dist:mac": "electron-builder --mac --universal",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.pdfsigner.app",
    "productName": "PDF Signer",
    "asar": false,
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "PDF Document",
        "role": "Editor",
        "icon": "build/icon.icns"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "PDF-Signer-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "PDF Signer ${version}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PDF Signer",
      "artifactName": "PDF-Signer-Setup.exe"
    }
  },
  "dependencies": {
    "@capacitor/app": "8.1.0",
    "@capacitor/browser": "8.0.3",
    "@capacitor/core": "8.4.1",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/share": "8.0.1",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "3.11.174",
    "signature_pad": "4.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "8.4.1",
    "@capacitor/cli": "8.4.1",
    "electron": "31.7.7",
    "electron-builder": "24.13.3",
    "vitest": "^4.1.9"
  }
}
