{
  "name": "pdf-signer",
  "version": "1.4.3",
  "description": "Offline desktop app (Windows + macOS) to view large PDFs, mark them up, measure by scale, and add cosmetic signatures/initials/dates.",
  "main": "src/main.js",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Killswit3h/PDF-Reader.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --x64",
    "dist:arm64": "electron-builder --win nsis --arm64",
    "dist:mac": "electron-builder --mac --universal",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.pdfsigner.app",
    "productName": "PDF Signer",
    "asar": false,
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "PDF Document",
        "role": "Editor",
        "icon": "build/icon.icns"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "PDF-Signer-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "PDF Signer ${version}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PDF Signer",
      "artifactName": "PDF-Signer-Setup.exe"
    }
  },
  "dependencies": {
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "3.11.174",
    "signature_pad": "4.2.0"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "24.13.3"
  }
}
