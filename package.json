{
  "name": "pdf-signer",
  "version": "1.1.0",
  "description": "Offline Windows desktop app to view PDFs and stamp cosmetic signatures, initials and dates onto them.",
  "main": "src/main.js",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Killswit3h/PDF-Reader.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --x64",
    "dist:arm64": "electron-builder --win nsis --arm64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.pdfsigner.app",
    "productName": "PDF Signer",
    "asar": false,
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PDF Signer",
      "artifactName": "PDF-Signer-Setup.exe"
    }
  },
  "dependencies": {
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "3.11.174",
    "signature_pad": "4.2.0"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "24.13.3"
  }
}
